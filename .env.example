# ===========================================================================
# Xentra Frontend (Vite + React) — Environment Variables Reference
# ===========================================================================
# The frontend is a Vite + React SPA.  All VITE_* variables are compiled
# into the static bundle at build time.
#
# Copy this file to .env and fill in your values:
#   cp frontend/.env.example frontend/.env
# ===========================================================================


# ═══════════════════════════════════════════════════════════════════════════
# 1. REQUIRED — Authentication & API
# ═══════════════════════════════════════════════════════════════════════════

# Discord OAuth2 Client ID (from Discord Developer Portal).
# Used for Discord login flow.
VITE_DISCORD_CLIENT_ID=

# Discord OAuth2 Redirect URI.
# Must match exactly what is registered in Discord Developer Portal.
# Typically: http://localhost:3000/auth/callback (dev)
# or:        https://xentra.xyz/auth/callback (prod)
VITE_DISCORD_REDIRECT_URI=http://localhost:5173/auth/callback

# Backend API base URL.
# Points to the running Xentra Django backend.
# In production this is the same origin or a Vercel proxy path.
# In development: http://localhost:8000/api/v1
VITE_API_URL=http://localhost:8000/api/v1


# ═══════════════════════════════════════════════════════════════════════════
# 2. WALLETCONNECT v2 (Wallet Integration)
# ═══════════════════════════════════════════════════════════════════════════
# Read by src/services/walletConnectService.js — bridges mobile crypto
# wallets to the frontend via QR code scanning.

# WalletConnect v2 Project ID.
# Get one free at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=


# ═══════════════════════════════════════════════════════════════════════════
# 3. OPTIONAL — HMAC Request Signing (Advanced)
# ═══════════════════════════════════════════════════════════════════════════
# Read by src/services/requestSigning.js — enables HMAC-SHA256 signed
# requests from the browser to the backend.
#
# ⚠️  SECURITY NOTE: Exposing the signing secret in the browser makes it
# visible to anyone who inspects the JavaScript source.  Frontend auth
# uses JWT Bearer tokens (Discord OAuth2), which is the correct approach
# for browser clients.  HMAC signing is primarily for bot→backend.
#
# Only set this if you fully understand the security implications and
# need signed frontend requests for a specific reason.

VITE_REQUEST_SIGNING_SECRET=


# ═══════════════════════════════════════════════════════════════════════════
# 4. VERCEL SERVERLESS — Discord Proxy (Server-Side Only)
# ═══════════════════════════════════════════════════════════════════════════
# Read by api/discord-proxy.js — a Vercel serverless function that proxies
# Discord API calls from HF Spaces (which is blocked by Cloudflare Bot
# Management at the TLS level).  This is NOT a VITE_ variable and must be
# set in the Vercel environment (Project Settings → Environment Variables).
#
#   DISCORD_PROXY_KEY        Shared key for X-Proxy-Key authentication
