# WalletConnect v2 Project ID
# Get one free at https://dashboard.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Backend API base URL
# Points to the running Xentra backend (same origin in production, or proxied in dev).
# Leave empty to default to the same origin, e.g. http://localhost:8000/api/v1
VITE_API_URL=
